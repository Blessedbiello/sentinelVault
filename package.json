{
  "name": "sentinel-vault",
  "version": "1.0.0",
  "description": "SentinelVault — Autonomous AI Agent Wallet Framework for Solana",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sentinel-vault": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn src/index.ts",
    "cli": "ts-node src/cli/index.ts",
    "demo": "ts-node scripts/demo.ts",
    "demo:multi": "ts-node scripts/demo-multi-agent.ts",
    "demo:trade": "ts-node scripts/demo-trading.ts",
    "dashboard": "ts-node src/dashboard/server.ts",
    "demo:showcase": "ts-node scripts/demo-showcase.ts",
    "demo:live": "ts-node scripts/live-dashboard-demo.ts",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "setup": "bash scripts/setup-devnet.sh"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.6",
    "bs58": "^5.0.0",
    "tweetnacl": "^1.0.3",
    "commander": "^12.1.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "inquirer": "^8.2.6",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "ws": "^8.16.0",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1",
    "cli-table3": "^0.6.5",
    "figlet": "^1.7.0",
    "boxen": "^5.1.2",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.8",
    "@types/inquirer": "^8.2.10",
    "@types/figlet": "^1.5.8",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "@types/jest": "^29.5.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
