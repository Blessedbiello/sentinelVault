SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=
DASHBOARD_PORT=3000
WEBSOCKET_PORT=3001
MAX_AGENTS=10
DEFAULT_SPENDING_LIMIT_PER_TX=1.0
DEFAULT_SPENDING_LIMIT_DAILY=20.0
LOG_LEVEL=info
AUDIT_LOG_DIR=.sentinelvault/audit
KEYSTORE_DIR=.sentinelvault/keystores

# Optional: AI Advisor integration (enables LLM-powered trade recommendations)
# Set one of these to enable the AI advisor; leave empty for pure quantitative mode
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
